{
  "manifest_version": 3,
  "name": "Clear Site Data (One Click)",
  "version": "1.0.0",
  "description": "One-click total clear of the current site's cache, cookies, and storage — same as DevTools 'Clear site data'. Optionally auto-refreshes the tab.",
  "permissions": [
    "browsingData",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Clear site data for this site",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
